/* ===== FUTURISTIC GLASS DARK THEME (Qt/PySide6) =====
   - Compatible Qt (no CSS variables)
   - Linear/Vercel-like: gradients + glass + subtle glow
*/

QWidget {
    font-family: "Inter","Segoe UI Variable","Segoe UI","-apple-system","Helvetica Neue",sans-serif;
    color: rgba(226,232,240,0.82);
    font-size: 14px;
    background: transparent;
}

/* Root background (deep space + cyan glow) */
QWidget#RootWindow {
    background: qradialgradient(
        cx:0.72, cy:0.18, radius:1.25,
        stop:0 rgba(56,189,248,0.16),
        stop:0.35 rgba(30,41,59,0.75),
        stop:1 rgba(2,6,23,1)
    );
}

/* Sections */
QWidget#HeroSection {
    background: transparent;
}

QWidget#FeaturesSection {
    background: transparent;
}

/* Separator */
QFrame#SoftSeparator {
    background: rgba(255,255,255,0.06);
}

/* Typography */
QLabel#HeroTitle {
    color: rgba(248,250,252,0.95);
    letter-spacing: -0.8px;
}

QLabel#HeroTitleAccent {
    color: rgba(56,189,248,0.98);
    letter-spacing: -0.8px;
}

QLabel#HeroSubtitle {
    color: rgba(148,163,184,0.92);
    line-height: 1.6em;
}

QLabel#SectionTitle {
    color: rgba(248,250,252,0.92);
    letter-spacing: -0.2px;
}

/* Buttons */
QPushButton {
    border: none;
    outline: none;
    border-radius: 14px;
    padding: 12px 18px;
}

QPushButton#PrimaryButton {
    color: white;
    font-weight: 800;
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 rgba(14,165,233,0.95),
        stop:1 rgba(99,102,241,0.95)
    );
}

QPushButton#PrimaryButton:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 rgba(56,189,248,0.98),
        stop:1 rgba(129,140,248,0.98)
    );
}

QPushButton#PrimaryButton:pressed {
    background: rgba(255,255,255,0.10);
}

QPushButton#SecondaryButton {
    color: rgba(226,232,240,0.92);
    font-weight: 800;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
}

QPushButton#SecondaryButton:hover {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(56,189,248,0.22);
}

/* Hero glass card */
QWidget#HeroCard {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 rgba(255,255,255,0.05),
        stop:1 rgba(255,255,255,0.02)
    );
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.08);
}

QLabel#HeroBadge {
    color: rgba(226,232,240,0.95);
    font-size: 34px;
}

QLabel#HeroCardTitle {
    color: rgba(56,189,248,0.95);
}

QLabel#HeroCardHint {
    color: rgba(148,163,184,0.92);
}

/* Feature cards */
QFrame#FeatureCard {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 rgba(255,255,255,0.045),
        stop:1 rgba(255,255,255,0.020)
    );
    border-radius: 26px;
    border: 1px solid rgba(255,255,255,0.07);
}

QFrame#FeatureCard:hover {
    border: 1px solid rgba(56,189,248,0.20);
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 rgba(255,255,255,0.060),
        stop:1 rgba(255,255,255,0.028)
    );
}

QLabel#CardIcon {
    font-size: 44px;
    margin-bottom: 4px;
}

QLabel#CardTitle {
    color: rgba(248,250,252,0.95);
    font-size: 16px;
    font-weight: 900;
}

QLabel#CardDescription {
    color: rgba(148,163,184,0.92);
    font-size: 13px;
    line-height: 1.6em;
}

/* Inputs (if used elsewhere) */
QLineEdit, QTextEdit, QPlainTextEdit {
    background: rgba(255,255,255,0.02);
    color: rgba(248,250,252,0.95);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 10px 12px;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border: 1px solid rgba(56,189,248,0.26);
    background: rgba(255,255,255,0.03);
}

/* Scrollbar */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
}
QScrollBar::handle:vertical {
    background: rgba(255,255,255,0.10);
    border-radius: 4px;
}
QScrollBar::handle:vertical:hover {
    background: rgba(255,255,255,0.14);
}
